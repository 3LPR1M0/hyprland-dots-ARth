@import "waybar-colors.css";
* {
  min-height: 30px;
  min-width: 15px;
  font-family: Lexend, "JetBrainsMono NFP";
  font-size: 16px;
  font-weight: 600;
}

 .modules-center {
	background-color: @color0;
	padding: 2px;
	 margin-top: 8px;
	border-radius: 99px;
}
 .modules-left {
	background-color: @color0;
	padding: 2px;
	 margin-top: 8px;
	border-radius: 99px;
	 margin-left: 12px;
}
 .modules-right {
	background-color: @color0;
	padding: 2px;
	 margin-top: 8px;
	border-radius: 99px;
	 margin-right: 12px;
}
window#waybar {
  transition-property: background-color;
  transition-duration: 0s;
  background-color: transparent;
}

  #tray {          /* add this */
  padding: 0.3rem 0.6rem;
  margin: 0.4rem 0.25rem;
  border-radius: 6px;
  background-color: @color0;


}
#workspaces button {
  padding: 2px 4px;
  border-radius: 99px;
  margin: 0 2px;
  min-width: 7px;
  transition: all 150ms cubic-bezier(0.25, 0.46, 0.45, 0.94);
  color: @color5;
  background-color: transparent;
}

#workspaces button.active {
  background-color: @color15;
  color: @color1;
  font-size: 18px;
  font-weight: 800;
  padding: 2px 8px;  /* slightly wider to match the bigger text */
}

#mpris {
  padding: 1px 8px;
  margin: 2px 4px;
  border-radius: 6px;
  /* background-color: #181825; */
  background-color: @color0;
}

#mpris.playing {
  color: @color12;
}

#mpris.paused {
  color: @color2;
}

#custom-sep {
  padding: 0px;
  color: @color14;
}

window#waybar.empty #window {
  background-color: transparent;
}

#clock {
  color: @color13;
  background-color: transparent;
}

#clock.simpleclock {
  color: @color14;
}

#window {
  color: @color11;
}

#pulseaudio {
  color: @color14;
  background-color: transparent;
}

#pulseaudio.muted {
  color: @color13;
}

#custom-logo {
  color: @color15;
}

#tooltip {
  background-color: @color0;
  border: 2px solid @color5;
}
#cava {
	color: @color13;
}
#network{
  color: @color13;
  background-color: transparent;
}
